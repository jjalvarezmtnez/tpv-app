<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane styleClass="screen-container"
           xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.jhonatan.tfg.tpv.controller.InformesController">

    <VBox spacing="16"
          alignment="CENTER"
          styleClass="card-container"
          maxWidth="1150">

        <!-- Cabecera de la vista -->
        <Label text="Informes del Sistema"
               styleClass="title-label" />

        <Label text="Consulta métricas, ventas e historial del negocio"
               styleClass="subtitle-label" />

        <!-- Filtro por fecha -->
        <HBox spacing="12" alignment="CENTER">
            <Label text="Fecha"
                   styleClass="section-label" />

            <DatePicker fx:id="fechaFiltroPicker" />

            <Button text="Aplicar filtro"
                    onAction="#handleAplicarFiltro"
                    styleClass="primary-button" />

            <Button text="Limpiar filtro"
                    onAction="#handleLimpiarFiltro"
                    styleClass="secondary-button" />
        </HBox>

        <Separator />

        <!-- Indicadores principales -->
        <HBox spacing="36" alignment="CENTER">
            <VBox spacing="8" alignment="CENTER_LEFT">
                <Label fx:id="ingresosLabel"
                       text="Ingresos totales: -"
                       styleClass="info-label" />

                <Label fx:id="comandasCerradasLabel"
                       text="Comandas cerradas: -"
                       styleClass="info-label" />
            </VBox>

            <VBox spacing="8" alignment="CENTER_LEFT">
                <Label fx:id="productosVendidosLabel"
                       text="Productos vendidos: -"
                       styleClass="info-label" />

                <Label fx:id="productoMasVendidoLabel"
                       text="Producto más vendido: -"
                       styleClass="info-label" />
            </VBox>
        </HBox>

        <Label fx:id="ultimaActualizacionLabel"
               text="Última actualización: -"
               styleClass="subtitle-label" />

        <Separator />

        <!-- Tablas de detalle -->
        <HBox spacing="22" alignment="CENTER">
            <VBox spacing="8" alignment="CENTER">
                <Label text="Resumen de productos vendidos"
                       styleClass="section-label" />

                <VBox styleClass="table-wrapper"
                      prefWidth="520">
                    <TableView fx:id="resumenProductosTableView"
                               prefWidth="520"
                               prefHeight="180">
                        <columns>
                            <TableColumn fx:id="productoResumenColumn"
                                         text="Producto" />

                            <TableColumn fx:id="unidadesResumenColumn"
                                         text="Unidades" />
                        </columns>
                    </TableView>
                </VBox>
            </VBox>

            <VBox spacing="8" alignment="CENTER">
                <Label text="Historial de ventas"
                       styleClass="section-label" />

                <VBox styleClass="table-wrapper"
                      prefWidth="520">
                    <TableView fx:id="historialVentasTableView"
                               prefWidth="520"
                               prefHeight="180">
                        <columns>
                            <TableColumn fx:id="mesaHistorialColumn"
                                         text="Mesa" />

                            <TableColumn fx:id="fechaHistorialColumn"
                                         text="Fecha" />

                            <TableColumn fx:id="totalHistorialColumn"
                                         text="Total" />
                        </columns>
                    </TableView>
                </VBox>
            </VBox>
        </HBox>

        <Separator />

        <!-- Gráficos estadísticos -->
        <HBox spacing="22" alignment="CENTER">
            <VBox spacing="8" alignment="CENTER">
                <Label text="Productos más vendidos"
                       styleClass="section-label" />

                <BarChart fx:id="productosVendidosChart"
                          prefWidth="460"
                          prefHeight="280"
                          legendVisible="false"
                          animated="false">
                    <xAxis>
                        <CategoryAxis label="Producto" />
                    </xAxis>
                    <yAxis>
                        <NumberAxis label="Unidades" />
                    </yAxis>
                </BarChart>
            </VBox>

            <VBox spacing="8" alignment="CENTER">
                <Label text="Ingresos por día"
                       styleClass="section-label" />

                <BarChart fx:id="ingresosPorDiaChart"
                          prefWidth="460"
                          prefHeight="280"
                          legendVisible="false"
                          animated="false">
                    <xAxis>
                        <CategoryAxis label="Fecha" />
                    </xAxis>
                    <yAxis>
                        <NumberAxis label="Ingresos (€)" />
                    </yAxis>
                </BarChart>
            </VBox>
        </HBox>

        <!-- Acciones generales -->
        <HBox spacing="12" alignment="CENTER">
            <Button text="Refrescar"
                    onAction="#handleRefrescar"
                    styleClass="primary-button" />

            <Button text="Volver al menú"
                    onAction="#handleVolverMenu"
                    styleClass="secondary-button" />
        </HBox>

        <!-- Mensajes de estado -->
        <Label fx:id="mensajeLabel"
               styleClass="message-label" />

    </VBox>

</StackPane>