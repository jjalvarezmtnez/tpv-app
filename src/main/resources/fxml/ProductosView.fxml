<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane styleClass="screen-container"
           xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.jhonatan.tfg.tpv.controller.ProductosController">

    <VBox spacing="16"
          alignment="CENTER"
          styleClass="card-container"
          maxWidth="860">

        <!-- Cabecera -->
        <Label text="Gestión de Productos"
               styleClass="title-label" />

        <Label text="Consulta, crea y actualiza productos del catálogo"
               styleClass="subtitle-label" />

        <!-- Tabla de productos -->
        <VBox styleClass="table-wrapper"
              prefWidth="760">
            <TableView fx:id="productosTableView"
                       prefWidth="760"
                       prefHeight="220">
                <columns>
                    <TableColumn fx:id="nombreColumn"
                                 text="Nombre" />

                    <TableColumn fx:id="precioColumn"
                                 text="Precio" />

                    <TableColumn fx:id="stockColumn"
                                 text="Stock" />

                    <TableColumn fx:id="categoriaColumn"
                                 text="Categoría" />
                </columns>
            </TableView>
        </VBox>

        <Separator />

        <!-- Formulario de producto -->
        <Label text="Datos del producto"
               styleClass="section-label" />

        <GridPane hgap="14"
                  vgap="12"
                  alignment="CENTER">

            <TextField fx:id="nombreField"
                       promptText="Nombre"
                       GridPane.columnIndex="0"
                       GridPane.rowIndex="0" />

            <TextField fx:id="precioField"
                       promptText="Precio"
                       GridPane.columnIndex="1"
                       GridPane.rowIndex="0" />

            <TextField fx:id="stockField"
                       promptText="Stock"
                       GridPane.columnIndex="0"
                       GridPane.rowIndex="1" />

            <ComboBox fx:id="categoriaComboBox"
                      promptText="Selecciona categoría"
                      GridPane.columnIndex="1"
                      GridPane.rowIndex="1" />
        </GridPane>

        <!-- Acciones CRUD -->
        <HBox spacing="12" alignment="CENTER">
            <Button text="Crear"
                    onAction="#handleCrearProducto"
                    styleClass="primary-button" />

            <Button fx:id="actualizarProductoButton"
                    text="Actualizar"
                    onAction="#handleActualizarProducto"
                    styleClass="primary-button" />

            <Button fx:id="eliminarProductoButton"
                    text="Eliminar"
                    onAction="#handleEliminarProducto"
                    styleClass="danger-button" />
        </HBox>

        <!-- Navegación -->
        <Button text="Volver al menú"
                onAction="#handleVolverMenu"
                styleClass="secondary-button" />

        <!-- Mensajes de estado -->
        <Label fx:id="mensajeLabel"
               styleClass="message-label" />

    </VBox>

</StackPane>