<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane styleClass="screen-container"
           xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.jhonatan.tfg.tpv.controller.CategoriasController">

    <VBox spacing="16"
          alignment="CENTER"
          styleClass="card-container"
          maxWidth="720">

        <!-- Cabecera de la vista -->
        <Label text="Gestión de Categorías"
               styleClass="title-label" />

        <Label text="Consulta, crea y actualiza categorías del sistema"
               styleClass="subtitle-label" />

        <!-- Listado principal de categorías -->
        <ListView fx:id="categoriasListView"
                  prefWidth="520"
                  prefHeight="260" />

        <Separator />

        <!-- Formulario de edición -->
        <Label text="Datos de la categoría"
               styleClass="section-label" />

        <TextField fx:id="nombreField"
                   promptText="Nombre de la categoría" />

        <!-- Acciones CRUD -->
        <HBox spacing="12" alignment="CENTER">
            <Button text="Crear"
                    onAction="#handleCrearCategoria"
                    styleClass="primary-button" />

            <Button fx:id="actualizarCategoriaButton"
                    text="Actualizar"
                    onAction="#handleActualizarCategoria"
                    styleClass="primary-button" />

            <Button fx:id="eliminarCategoriaButton"
                    text="Eliminar"
                    onAction="#handleEliminarCategoria"
                    styleClass="danger-button" />
        </HBox>

        <!-- Navegación -->
        <Button text="Volver al menú"
                onAction="#handleVolverMenu"
                styleClass="secondary-button" />

        <!-- Mensajes de estado -->
        <Label fx:id="mensajeLabel"
               styleClass="message-label" />

    </VBox>

</StackPane>