<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane styleClass="screen-container"
           xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.jhonatan.tfg.tpv.controller.MainMenuController">

    <VBox spacing="18"
          alignment="CENTER"
          styleClass="card-container"
          maxWidth="620">

        <!-- Cabecera -->
        <Label text="Menú Principal"
               styleClass="title-label" />

        <Label text="Selecciona el módulo que deseas gestionar"
               styleClass="subtitle-label" />

        <Label fx:id="usuarioActualLabel"
               text="Usuario: -"
               styleClass="info-label" />

        <Separator />

        <!-- Navegación por módulos -->
        <GridPane hgap="14"
                  vgap="14"
                  alignment="CENTER">

            <Button text="Mesas"
                    onAction="#irAMesas"
                    styleClass="primary-button"
                    prefWidth="220"
                    GridPane.columnIndex="0"
                    GridPane.rowIndex="0" />

            <Button fx:id="productosButton"
                    text="Productos"
                    onAction="#irAProductos"
                    styleClass="secondary-button"
                    prefWidth="220"
                    GridPane.columnIndex="1"
                    GridPane.rowIndex="0" />

            <Button fx:id="categoriasButton"
                    text="Categorías"
                    onAction="#irACategorias"
                    styleClass="secondary-button"
                    prefWidth="220"
                    GridPane.columnIndex="0"
                    GridPane.rowIndex="1" />

            <Button fx:id="usuariosButton"
                    text="Usuarios"
                    onAction="#irAUsuarios"
                    styleClass="secondary-button"
                    prefWidth="220"
                    GridPane.columnIndex="1"
                    GridPane.rowIndex="1" />

            <Button fx:id="informesButton"
                    text="Informes"
                    onAction="#irAInformes"
                    styleClass="secondary-button"
                    prefWidth="220"
                    GridPane.columnIndex="0"
                    GridPane.rowIndex="2" />
        </GridPane>

        <Separator />

        <!-- Acción de sesión -->
        <Button text="Cerrar sesión"
                onAction="#handleCerrarSesion"
                styleClass="danger-button"
                prefWidth="220" />

    </VBox>

</StackPane>