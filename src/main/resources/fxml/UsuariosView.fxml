<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane styleClass="screen-container"
           xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.jhonatan.tfg.tpv.controller.UsuariosController">

    <VBox spacing="16"
          alignment="CENTER"
          styleClass="card-container"
          maxWidth="860">

        <!-- Cabecera -->
        <Label text="Gestión de Usuarios"
               styleClass="title-label" />

        <Label text="Administra usuarios y roles del sistema"
               styleClass="subtitle-label" />

        <!-- Tabla de usuarios activos -->
        <VBox styleClass="table-wrapper"
              prefWidth="760">
            <TableView fx:id="usuariosTableView"
                       prefWidth="760"
                       prefHeight="220">
                <columns>
                    <TableColumn fx:id="usernameColumn"
                                 text="Username" />

                    <TableColumn fx:id="nombreColumn"
                                 text="Nombre" />

                    <TableColumn fx:id="rolColumn"
                                 text="Rol" />
                </columns>
            </TableView>
        </VBox>

        <Separator />

        <!-- Formulario de usuario -->
        <Label text="Datos del usuario"
               styleClass="section-label" />

        <GridPane hgap="14"
                  vgap="12"
                  alignment="CENTER">

            <TextField fx:id="usernameField"
                       promptText="Username"
                       GridPane.columnIndex="0"
                       GridPane.rowIndex="0" />

            <TextField fx:id="nombreField"
                       promptText="Nombre"
                       GridPane.columnIndex="1"
                       GridPane.rowIndex="0" />

            <PasswordField fx:id="passwordField"
                           promptText="Contraseña"
                           GridPane.columnIndex="0"
                           GridPane.rowIndex="1" />

            <ComboBox fx:id="rolComboBox"
                      promptText="Selecciona un rol"
                      GridPane.columnIndex="1"
                      GridPane.rowIndex="1" />
        </GridPane>

        <!-- Acciones CRUD -->
        <HBox spacing="12" alignment="CENTER">
            <Button text="Crear"
                    onAction="#handleCrearUsuario"
                    styleClass="primary-button" />

            <Button fx:id="actualizarUsuarioButton"
                    text="Actualizar"
                    onAction="#handleActualizarUsuario"
                    styleClass="primary-button" />

            <Button fx:id="desactivarUsuarioButton"
                    text="Desactivar"
                    onAction="#handleDesactivarUsuario"
                    styleClass="danger-button" />
        </HBox>

        <!-- Navegación -->
        <Button text="Volver al menú"
                onAction="#handleVolverMenu"
                styleClass="secondary-button" />

        <!-- Mensajes de estado -->
        <Label fx:id="mensajeLabel"
               styleClass="message-label" />

    </VBox>

</StackPane>